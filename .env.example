APP_NAME=Catch Your Partner API
ENVIRONMENT=development
DEBUG=true
JWT_SECRET=change-me-in-production
POSTGRES_URL=postgresql+psycopg://postgres:postgres@db:5432/catchyourpartner
CORS_ALLOW=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
RATE_LIMIT_ENABLED=true
RATE_LIMIT=120
AUTH_RATE_LIMIT_PER_MINUTE=20
RADAR_TTL_MINUTES=60
CHAT_EXPIRY_HOURS=48
CHAT_MESSAGE_LIMIT=20
CHECKIN_RADIUS_METERS=250
AUTO_CREATE_TABLES=false
LOG_LEVEL=INFO
DEFAULT_ADMIN_EMAIL=admin@example.com
FEATURE_CORE_ENABLED=true
FEATURE_IDENTITY_ENABLED=false
FEATURE_COMPANION_ENABLED=false
FEATURE_MIND_ENABLED=false
FEATURE_ASTRO_ENABLED=false
